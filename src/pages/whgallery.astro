<style>
* {
  box-sizing: border-box;
  
}

  
p {
  white-space: pre-wrap;
}  


/* Header/logo Title */
.header {
  display: flex;
  flex-direction: column-reverse;
  color: #173936;
  background: #328078; 
  min-height: 10cqi;
  position: relative;
  border-bottom: 35px solid #1d1d1d;
}

.hero-header {
  display: flex;
  flex-direction: column-reverse;
  color: #F2DBC6;
  background-image: linear-gradient(rgba(23, 57, 54, .9), rgba(23, 57, 54, .8), rgba(29, 29, 29, 1)), url("https://www.cindyliuconcepts.com/fan/mha/Fxa4jrSaIAAfxRB.jpg");
  height: 50cqi;
  background-repeat: no-repeat;
  background-size: 125%;
  background-position-x: 9%;
  background-position-y: 30%; 
  background-blend-mode: darken;
  position: relative;

}

/* Increase the font size of the heading */
.hero-header h1 {
  font-size: clamp(3rem, 12cqi, 22rem);
  color: #AF453C;
  font-weight: 900;
  letter-spacing: -0.4cqi;
  line-height: 65%;
  position: absolute;
  bottom:-5px;

}

.header h1 {
  font-size: clamp(1rem, 8cqi, 10rem);
  color: #1d1d1d;
  font-weight: 900;
  letter-spacing: -0.4cqi;
  line-height: 65%;
  position: absolute;
  bottom:-5px;

}

.header .blurb, .hero-header .blurb {
  max-width: 60%;
  text-align: right;
  font-size: 3.5cqi;
  font-weight: 200;
  line-height: 1cqi;
  position: absolute;
  right: 30px;
  top: 40px;
 }
 
 
 @media screen and (max-width: 700px) {
 
 .header {
  min-height: 13cqi;
  }
 
.header h1, .hero-header h1 {
  bottom: -5px;
  }
}


@media screen and (max-width: 400px) {

.header {
  padding: 1em;
  min-height: auto;
  align-items: center;
   justify-content: center;
  flex-direction: column-reverse;
  }

.hero-header {
 background-size: 150%;
 min-height: 250;
  align-items: center;
   justify-content: center;
  flex-direction: column-reverse;
 }


.header h1, .hero-header h1 {
