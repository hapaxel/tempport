  right: auto;
  top: auto;
  bottom: auto;
}

}



h2, h3, h4 {
  color: #CF000A;
}


/* Sticky navbar - toggles between relative and fixed, depending on the scroll position. It is positioned relative until a given offset position is met in the viewport - then it "sticks" in place (like position:fixed). The sticky value is not supported in IE or Edge 15 and earlier versions. However, for these versions the navbar will inherit default position */
.navbar {
  overflow: hidden;
  background-color: #AF453C;
  position: sticky;
  position: -webkit-sticky;
  top: 0;
  padding-top: 10px;
  z-index: 1;
}

/* Style the navigation bar links */
.navbar a {
  float: left;
  display: block;
  color: #F2DBC6;
  text-align: center;
  padding: 5px 20px;
  text-decoration: none;
  font-variant: small-caps;
  font-size: 1.3rem;
  font-weight: 350;
  border-bottom: 5px solid transparent;
}


/* Right-aligned link */
.navbar a.right {
  float: right;
}

/* Change color on hover */
.navbar a:hover {
  border-bottom: 5px solid #FED801;
  
}

/* Active/current link */
.navbar a.active {
  border-bottom: 5px solid #CF000A;
}

/* Column container */
.row {  
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  background: #1d1d1d;
  color: #F2DBC6;
  padding: 2em 3em 0 3em;
  width: 100%;
}

/* Create two unequal columns that sits next to each other */
/* Sidebar/left column */
.side {
  -ms-flex: 25%; /* IE10 */
  flex: 25%;
  
  padding: 20px;
   
}

/* Main column */
.main {   
  -ms-flex: 75%; /* IE10 */
  flex: 75%;
  
  padding: 20px;
   
}

/* Fake image, just for this example */
.fakeimg {
  background-color: #aaa;
  width: 100%;
  padding: 20px;
}


.card {
  position: relative;
  background-color: #180E0F;
  border-radius: 0.25rem;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin: .75em;
  padding: 2em;
  align-items: center;
  width: 100%;
  }
  
  .card_content {
  font-size: 13px;
  margin-left: 1em;
  
  }

  .card_content h4 {
  padding-top: .5rem;
  margin-left: -1em;
  
  }

  .card_image {
  max-height: 300px; 
  
 
  }
  
  
.flex-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.flex-container div{
	margin: .75em;
      padding: 1em;
}

.filterDiv {
  float: left;
  width: 250px;
  line-height: 100px;
  text-align: center;
  margin: 2px;
  display: none; /* Hidden by default */
}
  
  
/* The "show" class is added to the filtered elements */
.show {
  display: block;
}
  

/* Style the tab */
.tab {
  overflow: hidden;
  background-color: #1D1D1D;
  color: #F2DBC6;
  justify-content: center;
}

/* Style the buttons inside the tab */
.tab button {
  background-color: #1D1D1D;
  float: center;
  border: 2px solid transparent;
  outline: none;
  cursor: pointer;
  padding: 3px 30px 10px;
  margin: 0px 20px;
  transition: 0.2s;
  font-variant: small-caps;
  font-size: clamp(1rem, 1.5cqi, 2rem);
  font-weight: 400;
  letter-spacing: 3px;
  text-transform: lowercase;
}

/* Change background color of buttons on hover */
.tab button:hover {
  border: 2px solid #FED801;
  color: #FED801;
}

/* Create an active/current tablink class */
.tab button.active {
  background-color: #1D1D1D;
  border: 2px solid #CF000A;
}
/* Style the tab content */
.tabcontent {
  display: none;
  padding: 30px 15px;
  border-top: none;
}


/* Footer */
.footer {
  padding: 20px;
  text-align: center;
  background: #1C140D;
}

@media screen and (max-width: 1024px) {
  .side {
     -ms-flex: 40%; /* IE10 */
    flex: 40%;
    }
  .main {   
    -ms-flex: 60%; /* IE10 */
    flex: 60%;
    }
}

@media screen and (max-width: 1440px) {
  .side {
     -ms-flex: 30%; /* IE10 */
    flex: 30%;
    }
  .main {   
    -ms-flex: 70%; /* IE10 */
    flex: 70%;
    }
}

/* Responsive layout - when the screen is less than 700px wide, make the two columns stack on top of each other instead of next to each other */
@media screen and (max-width: 700px) {
  .row {   
    flex-direction: column;
  }
}

/* Responsive layout - when the screen is less than 400px wide, make the navigation links stack on top of each other instead of next to each other */
@media screen and (max-width: 400px) {
  .navbar a {
    float: none;
    width: 100%;
  }  
}
  

</style>

<script>

filterSelection("all")
function filterSelection(c) {
  var x, i;
  x = document.getElementsByClassName("filterDiv");
  if (c == "all") c = "";
  // Add the "show" class (display:block) to the filtered elements, and remove the "show" class from the elements that are not selected
  for (i = 0; i < x.length; i++) {
    w3RemoveClass(x[i], "show");
    if (x[i].className.indexOf(c) > -1) w3AddClass(x[i], "show");
  }
}

// Show filtered elements
function w3AddClass(element, name) {
  var i, arr1, arr2;
  arr1 = element.className.split(" ");
  arr2 = name.split(" ");
  for (i = 0; i < arr2.length; i++) {
    if (arr1.indexOf(arr2[i]) == -1) {
      element.className += " " + arr2[i];
    }
  }
}

// Hide elements that are not selected
function w3RemoveClass(element, name) {
  var i, arr1, arr2;
  arr1 = element.className.split(" ");
  arr2 = name.split(" ");
  for (i = 0; i < arr2.length; i++) {
    while (arr1.indexOf(arr2[i]) > -1) {
      arr1.splice(arr1.indexOf(arr2[i]), 1);
    }
  }
  element.className = arr1.join(" ");
}

// Add active class to the current control button (highlight it)
var btnContainer = document.getElementById("myBtnContainer");
var btns = btnContainer.getElementsByClassName("btn");
for (var i = 0; i < btns.length; i++) {
  btns[i].addEventListener("click", function() {
    var current = document.getElementsByClassName("gg");
    current[0].className = current[0].className.replace(" gg", "");
    this.className += " gg";
  });
}
</script>

</head>

