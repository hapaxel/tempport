---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	
<style>
.container {
  display: flex;
  justify-content: space-evenly;
}

.container div {
  width: 100%;
  margin: 10px;
  padding: 10px;
  text-align: center;  
  font-size: 12px;
  text-transform: uppercase;
}
</style>
</head>
<body>
<Header  />

<main>

	<p>
		Cindy is a freelance Concept Artist, Illustrator, and Skull Enthusiast! Currently working out of Los Angeles, CA. I studied traditionally at the Academy of Art University of San Francisco.
	</p>

	<p>
	<div class="container">
  <div>email</div>
  <div>resume</div>
</div>

	<p>
		Published works:
	</p>
<p>
  <div class="container">
  <div>The Pathless</div>
  <div>Sword and the Sea</div>
</div>
</p>

</main>
<Footer />
	</body>
</html>
