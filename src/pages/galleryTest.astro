      <img src="https://www.cindyliuconcepts.com/napolean_poster-protected-intensity-LOW-V2.png" alt="Napolean Dolphin Poster">
    </a>
  </div>

  <div class="gallery-item creature">
    <a target="_blank" href="https://www.cindyliuconcepts.com/image-asset-protected-intensity-LOW-V2.png">
      <img src="https://www.cindyliuconcepts.com/image-asset-protected-intensity-LOW-V2.png" alt="Bog Chicken">
    </a>
  </div>

  <div class="gallery-item creature enviro">
    <a target="_blank" href="https://www.cindyliuconcepts.com/karkadannil5_o_2000-protected-intensity-LOW-V2.png">
      <img src="https://www.cindyliuconcepts.com/karkadannil5_o_2000-protected-intensity-LOW-V2.png" alt="Karkadann">
    </a>
  </div>

  <div class="gallery-item creature char">
