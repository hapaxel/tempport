<style>
.gallery-container {
 display: grid;
  grid-template-columns: auto auto auto;
  gap: .75rem;
  padding: 0px;
  height: auto;
  width: 100%;
}

.gallery-item {
  border: 0px;
  overflow: hidden;
  display: none; /* Hidden by default */
}

.gallery-item.show {
  display: block; /* Show when filtered */
}

.gallery-item:hover {
  border: 0px;
  opacity: 0.7;
}

.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}


@media only screen and (max-width: 900px) {
  .gallery-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media only screen and (max-width: 500px) {
  .gallery-container {
    grid-template-columns: 1fr;
  }
}

/* Style the buttons */
.btn {
  border: 2px solid var(--color-contrast-higher);
  text-align: center;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: .5px;
  font-size: 11px;
  padding: 12px 16px;
  background-color: white;
  color: black;
  cursor: pointer;
  margin: 5px 2px;
}

/* Add a light grey background on mouse-over */
.btn:hover {
  background-color: black;
  color: white;
}

/* Add a dark background to the active button */
.btn.active {
  background-color: var(--accent);
  color: white;
  border: 0px solid var(--color-contrast-higher);
}

.btnContainer {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  flex-flow: row wrap;
}

.btnContainer a.split {
  float: right;
}

</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initial load - show all items
  filterSelection("all");
  
  function filterSelection(c) {
    var x = document.getElementsByClassName("gallery-item");
    if (c == "all") c = "";
    
    for (var i = 0; i < x.length; i++) {
      if (c == "" || x[i].className.indexOf(c) > -1) {
        x[i].classList.add("show");
      } else {
        x[i].classList.remove("show");
      }
    }
  }

  // Add click event listeners to buttons
  var btns = document.getElementsByClassName("btn");
  for (var i = 0; i < btns.length; i++) {
    btns[i].addEventListener("click", function() {
      // Remove active class from all buttons
      var current = document.getElementsByClassName("active");
      if (current.length > 0) {
        current[0].classList.remove("active");
      }
      // Add active class to clicked button
      this.classList.add("active");
      
      // Get filter value from onclick attribute
      var onclickAttr = this.getAttribute("onclick");
      var filterValue = onclickAttr.match(/'([^']*)'/)[1];
      filterSelection(filterValue);
    });
  }
});
</script>

</head>
<body>
